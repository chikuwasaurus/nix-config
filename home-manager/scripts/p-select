#!/usr/bin/env zsh

set -euo pipefail

# Select a project directory and print its absolute path to stdout.
#
# This script intentionally does not `cd` or open an editor.
# Changing the caller's working directory must be done by a shell function
# such as zsh's function or nushell's `def --env`.
#
# Usage:
#   p-select [DEV_DIR]
#
# If DEV_DIR is omitted, use $DEV_DIR, then ~/Developer as fallback.

DEV_DIR="${1:-${DEV_DIR:-$HOME/Developer}}"

require() {
  command -v "$1" >/dev/null 2>&1 || {
    print -u2 "$1 is not found"
    exit 1
  }
}

# fzf is required for project selection.
# bat is required for README preview.
require fzf
require bat

project_name="$(
  find "$DEV_DIR" -mindepth 1 -maxdepth 1 -type d -exec basename {} \; |
    sort |
    fzf \
      --prompt="Project > " \
      --preview="bat --color=always --style=header,grid --line-range :80 \"$DEV_DIR\"/{}/README.* 2>/dev/null || ls -la \"$DEV_DIR\"/{}"
)"

# If fzf is cancelled, output nothing and exit successfully.
# The caller can treat empty output as "do nothing".
[[ -z "${project_name:-}" ]] && exit 0

print -r -- "$DEV_DIR/$project_name"
