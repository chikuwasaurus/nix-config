// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run `zed: open default settings` from the
// command palette (cmd-shift-p / ctrl-shift-p)
{
  "buffer_font_family": "UDEV Gothic 35NF",
  "terminal": {
    "font_family": "UDEV Gothic 35NF",
  },
  "languages": {
    // Config: https://github.com/zed-extensions/nix
    "Nix": {
      "language_servers": ["nixd", "!nil"],
      "formatter": {
        "external": {
          "command": "nixfmt",
          // "arguments": ["--quiet", "--"],
        },
      },
    },
  },
  "auto_install_extensions": {
    "astro": true,
    "ghostty": true,
    "git-firefly": true,
    "github-theme": true,
    "html": true,
    "lua": true,
    "markdownlint": true,
    "nix": true,
    "nu": true,
    "toml": true,
  },
  "show_edit_predictions": false,
  "edit_predictions": {
    "copilot": {
      "enable_next_edit_suggestions": true,
    },
    "provider": "copilot",
  },
  "agent_servers": {
    "claude-acp": {
      "type": "registry",
    },
    "codex-acp": {
      "type": "registry",
    },
  },
  "autosave": "on_focus_change",
  "buffer_font_features": {
    "calt": false,
  },
  "project_panel": {
    "dock": "left",
  },
  "icon_theme": {
    "mode": "dark",
    "light": "Zed (Default)",
    "dark": "Zed (Default)",
  },
  "cli_default_open_behavior": "new_window",
  "outline_panel": {
    "dock": "left",
  },
  "collaboration_panel": {
    "dock": "left",
  },
  "agent": {
    "dock": "right",
    "favorite_models": [],
    "model_parameters": [],
    "default_model": {
      "provider": "openai-subscribed",
      "model": "gpt-5.5",
    },
    "commit_message_model": {
      "provider": "openai-subscribed",
      "model": "gpt-5.5",
      "enable_thinking": true,
      "effort": "low",
    },
  },
  "git_panel": {
    "tree_view": true,
    "dock": "left",
  },
  "telemetry": {
    "diagnostics": false,
    "metrics": false,
  },
  "ui_font_size": 16,
  "buffer_font_size": 13.0,
  "theme": {
    "mode": "dark",
    "light": "GitHub Light",
    "dark": "GitHub Dark Dimmed",
  },
}
