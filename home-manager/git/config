[init]
	defaultBranch = main
[user]
	email = 285532703+chikuwasaurus@users.noreply.github.com
	name = Chikuwa Saurus

[core]
	pager = delta

[interactive]
	diffFilter = delta --color-only

[include]
	path = ~/.config/delta/catppuccin.gitconfig

[delta]
	navigate = true  # use n and N to move between diff sections
	dark = true      # or light = true, or omit for auto-detection
	line-numbers = true
	side-by-side = true
	features = catppuccin-mocha
	hyperlinks = true # commit hashes link to GitHub/GitLab/Bitbucket

[merge]
	conflictStyle = zdiff3

[ghq]
	root = ~/Developer
	user = chikuwasaurus

[alias]
	# status
	s = status
	ss = status -sb

	# log
	l = log --oneline --decorate -n 20
	ll = log --stat --decorate -n 10
	lg = log --graph --oneline --decorate --all
	graph = log --graph --pretty=format:'%C(auto)%h %d %s %C(dim white)(%cr) <%an>' --all

	# diff
	d = diff
	ds = diff --staged
	dw = diff --word-diff
	de = "!git diff HEAD --name-only | fzf -m | xargs ${EDITOR:-hx}"

	# add / commit
	a = add
	aa = add -A
	ci = commit
	cm = commit -m
	cz = "!czg"
	amend = commit --amend
	amendn = commit --amend --no-edit

	# branch
	br = branch
	ba = branch -a
	sw = switch
	swc = switch -c

	# fetch / pull / push
	f = fetch --prune
	pl = pull --ff-only
	ps = push
	psu = push -u origin HEAD

	# rebase / merge
	rb = rebase
	rbi = rebase -i
	rbc = rebase --continue
	rba = rebase --abort
	mg = merge

	# stash
	sl = stash list
	sp = stash push -u
	sa = stash apply
	spo = stash pop

	# restore / reset
	unstage = restore --staged
	discard = restore
	undo = reset --soft HEAD~1

	# utils
	aliases = config --get-regexp ^alias\\.
	root = rev-parse --show-toplevel
	who = shortlog -sn

	# hunk
	hdiff = "-c core.pager=\"hunk pager\" diff"
	hshow = "-c core.pager=\"hunk pager\" show"

[pull]
	ff = only

[credential "https://github.com"]
	helper =
	helper = ! gh auth git-credential
[credential "https://gist.github.com"]
	helper =
	helper = ! gh auth git-credential
