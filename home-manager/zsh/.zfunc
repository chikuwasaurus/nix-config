# Open a selected project with the given editor.
#
# This must be a shell function, not an external script, because it changes the
# current shell's working directory with `cd`.
#
# Internal helper:
#   _p zed  [DEV_DIR]
#   _p nvim [DEV_DIR]
#
# Public commands:
#   pz [DEV_DIR]  # select project, cd into it, open with Zed
#   pn [DEV_DIR]  # select project, cd into it, open with Neovim
_p() {
  local editor="$1"
  shift

  local project
  project="$(p-select "$@")" || return
  [[ -z "$project" ]] && return 0

  cd "$project" || return

  case "$editor" in
    zed)
      command -v zed >/dev/null 2>&1 || {
        print -u2 "zed is not found"
        return 1
      }

      zed "$project"
      ;;

    nvim)
      command -v nvim >/dev/null 2>&1 || {
        print -u2 "nvim is not found"
        return 1
      }

      nvim "$project"
      ;;

    *)
      print -u2 "unknown editor: $editor"
      return 1
      ;;
  esac
}

# Select a project, cd into it, and open it with Zed.
zp() {
  _p zed "$@"
}

# Select a project, cd into it, and open it with Neovim.
np() {
  _p nvim "$@"
}
